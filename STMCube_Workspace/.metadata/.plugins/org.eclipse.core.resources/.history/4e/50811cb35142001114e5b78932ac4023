// adar2001.c
#include "adar2001.h"
#include "stm32f1xx_hal.h"
void ADAR2001_WriteReg(SPI_HandleTypeDef *hspi, uint16_t addr, uint8_t data)
{
    uint8_t tx[3];

    // 16-bit address (write bit = 0) + 8-bit data
    uint16_t addr_word = (ADAR2001_WRITE | (addr & 0x7FFF));

    tx[0] = (addr_word >> 8) & 0xFF;   // Address high byte
    tx[1] = addr_word & 0xFF;           // Address low byte
    tx[2] = data;                        // Data byte

    HAL_GPIO_WritePin(NSS_ADAR2001_GPIO_PORT, NSS_ADAR2001_PIN, GPIO_PIN_RESET);
    HAL_SPI_Transmit(hspi, tx, 3, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(NSS_ADAR2001_GPIO_PORT, NSS_ADAR2001_PIN, GPIO_PIN_SET);
}

uint8_t ADAR2001_ReadReg(SPI_HandleTypeDef *hspi, uint16_t addr)
{
    uint8_t tx[3];
    uint8_t rx[3] = {0};

    // Set read bit
    uint16_t addr_word = (ADAR2001_READ | (addr & 0x7FFF));

    tx[0] = (addr_word >> 8) & 0xFF;
    tx[1] = addr_word & 0xFF;
    tx[2] = 0x00;                        // Dummy byte for read

    HAL_GPIO_WritePin(NSS_ADAR2001_GPIO_Port, NSS_ADAR2001_Pin, GPIO_PIN_RESET);
    HAL_SPI_TransmitReceive(hspi, tx, rx, 3, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(NSS_ADAR2001_GPIO_Port, NSS_ADAR2001_Pin, GPIO_PIN_SET);

    return rx[2];                        // Data is in third byte
}

void ADAR2001_EnableAllChannels(SPI_HandleTypeDef *hspi)
{
    // Enable all 4 TX output channels
    ADAR2001_WriteReg(hspi, ADAR2001_REG_TX_EN1, ADAR2001_TX_EN_ALL);
    ADAR2001_WriteReg(hspi, ADAR2001_REG_TX_EN2, ADAR2001_TX_EN_ALL);
}

void ADAR2001_SetMultiplierBand(SPI_HandleTypeDef *hspi, uint8_t band_setting)
{
    ADAR2001_WriteReg(hspi, ADAR2001_REG_MULT_EN, band_setting);
}

void ADAR2001_Init(SPI_HandleTypeDef *hspi)
{
    // Software reset
    ADAR2001_WriteReg(hspi, ADAR2001_REG_CONFIG, 0x81);
    HAL_Delay(10);
    ADAR2001_WriteReg(hspi, ADAR2001_REG_CONFIG, 0x00);
    HAL_Delay(10);

    // Set SPI to 4-wire mode (separate SDO pin)
    ADAR2001_WriteReg(hspi, ADAR2001_REG_CONFIG, 0x18);

    // Configure input buffer bias (recommended default values)
    ADAR2001_WriteReg(hspi, ADAR2001_REG_INBUF, 0x55);

    // Configure multiplier bias (recommended default values)
    ADAR2001_WriteReg(hspi, ADAR2001_REG_MULT1, 0x55);
    ADAR2001_WriteReg(hspi, ADAR2001_REG_MULT2, 0x55);

    // Configure splitter bias (recommended default values)
    ADAR2001_WriteReg(hspi, ADAR2001_REG_SPLITTER, 0x55);

    // Set multiplier to high band for 7-8 GHz input → 28-32 GHz output
    ADAR2001_SetMultiplierBand(hspi, ADAR2001_MULT_HIGHBAND);

    // Disable low pass notch filter (required for >16 GHz output)
    ADAR2001_WriteReg(hspi, ADAR2001_REG_LPF, ADAR2001_LPF_DISABLE);

    // Enable all 4 transmit output channels
    ADAR2001_EnableAllChannels(hspi);
}
